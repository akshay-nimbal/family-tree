# Copy this file to `.env.local`.

# ---- Neo4j (server-side only) ----
# Local dev (docker compose / podman):
#   NEO4J_URI=bolt://localhost:7687
#   NEO4J_USER=neo4j
#   NEO4J_PASSWORD=vamsha_dev_password
#   # leave NEO4J_DATABASE unset (defaults to "neo4j")
#
# Neo4j Aura (encrypted + routing, one database per instance):
#   NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
#   NEO4J_USER=<aura username>
#   NEO4J_PASSWORD=<aura password>
#   NEO4J_DATABASE=<instance id>
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=

# ---- Frontend API base ----
# Leave empty (or unset) to talk to the Next.js API routes on this same origin.
NEXT_PUBLIC_API_URL=

# ---- Uploads ----
# Directory on disk for user-uploaded photos. Relative paths resolve from the
# repo root. Keep it outside of `public/` so uploads aren't bundled into the
# build output. Served at /uploads/<filename> via a route handler.
UPLOADS_DIR=uploads
