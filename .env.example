# Copy this file to `.env.local`.

# ---- Neo4j (server-side only) ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=vamsha_dev_password

# ---- Frontend API base ----
# Leave empty (or unset) to talk to the Next.js API routes in this same app
# (same-origin). Only set this to an external URL if you want the frontend
# to hit the legacy Express backend in `../backend` instead.
NEXT_PUBLIC_API_URL=

# ---- Uploads ----
# Directory on disk for user-uploaded photos. Relative paths resolve from the
# next-app/ root. Keep it outside of `public/` so they aren't bundled into the
# build output. Served at /uploads/<filename> via a route handler.
UPLOADS_DIR=uploads
